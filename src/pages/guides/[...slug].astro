---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((g) => ({ params: { slug: g.id }, props: { guide: g } }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const d = guide.data;
const dateStr = d.publishedAt.toISOString().slice(0, 10);

// hero(대표) 이미지 — 관례상 /og/{slug}.png, frontmatter로 재정의 가능
const heroSrc = d.heroImage ?? `/og/${guide.id}.png`;
const heroAlt = d.heroAlt ?? d.title;

// schema.org image: hero(1200x630) + 본문 다이어그램(1200x800)
const schemaImages = [
  { '@type': 'ImageObject', url: `https://babyskinlab.com${heroSrc}`, width: 1200, height: 630, name: heroAlt },
  ...(d.images?.map((im) => ({
    '@type': 'ImageObject',
    url: `https://babyskinlab.com${im.src}`,
    width: 1200,
    height: 800,
    name: im.alt,
    caption: im.caption,
  })) ?? []),
];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: d.title,
  description: d.description,
  datePublished: d.publishedAt.toISOString(),
  dateModified: (d.updatedAt ?? d.publishedAt).toISOString(),
  author: { '@type': 'Organization', name: 'Baby Skin Lab' },
  publisher: { '@type': 'Organization', name: '주식회사 빌리지베이비' },
  inLanguage: 'ko',
  ...(d.keywords?.length ? { keywords: d.keywords.join(', ') } : {}),
  image: schemaImages,
};

const faqSchema = d.faq?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: d.faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;
---
<Base title={d.title} description={d.description} ogType="article" ogImage={heroSrc} ogImageAlt={heroAlt}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>
  <article class="article wrap">
    <h1>{d.title}</h1>
    <p class="meta">발행 {dateStr} · Baby Skin Lab</p>
    <img class="lead-hero" src={heroSrc} alt={heroAlt} width="1200" height="630" loading="eager" />
    <Content />
    {d.faq?.length && (
      <section>
        <h2>자주 묻는 질문</h2>
        {d.faq.map((f) => (
          <details class="faq-item" open>
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </section>
    )}
    {d.relatedTool && (
      <a class="tool-cta" href={d.relatedTool}>🔍 글보다 빠른 답이 필요하다면 — 판정 도구 사용해보기 →</a>
    )}
  </article>
</Base>
